# Telegram API credentials
TG_API_ID=0
TG_API_HASH=
TG_PHONE=
TG_BOT_TOKEN=

# Proxy (optional)
TG_PROXY_URL=

# Database
TG_DATA_DIR=./data
TG_DB_PATH=./data/db.sqlite

# Sync config
TG_SYNC_BATCH_SIZE=500
TG_SYNC_BULK_API_LIMIT=10000
TG_SYNC_DELAY_SECONDS=1.0

# Thumbnail config
TG_THUMB_MAX_WIDTH=320
TG_THUMB_MAX_HEIGHT=240
TG_THUMB_VIDEO_CHUNK_PREVIEW_MB=20
TG_THUMB_WORKERS=2
TG_THUMB_JOB_TIMEOUT=600

# Cache config
TG_CACHE_MAX_SIZE_MB=0

# Server
TG_HOST=0.0.0.0
TG_PORT=8000
TG_ADMIN_PASSWORD=
TG_DEBUG=false

# Logging
TG_LOG_LEVEL=INFO
TG_LOG_FILE=./data/app.log
TG_LOG_ROTATION=10 MB
TG_LOG_RETENTION=5
